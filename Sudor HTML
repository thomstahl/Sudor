<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nnom's Sudor — Game Viewer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&family=IM+Fell+English:ital@0;1&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════════════════
   RESET & VARIABLES
═══════════════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:       #080b07;
  --bg2:      #0d120a;
  --bg3:      #111608;
  --border:   #1e2812;
  --border2:  #2a3818;
  --gold:     #c8a840;
  --gold2:    #e4c060;
  --green:    #6ab840;
  --green2:   #88c860;
  --muted:    #4a5a38;
  --text:     #c0c8a0;
  --text2:    #8a9870;
  --text3:    #5a6848;
  --danger:   #c05030;
  --water:    #1a3060;
  --panel-w:  300px;
  --hdr-h:    48px;
}
html, body { width:100%; height:100%; overflow:hidden; background:var(--bg); color:var(--text); font-family:'Crimson Text',serif; font-size:15px; }

/* ═══════════════════════════════════════════════════════════════════
   HEADER
═══════════════════════════════════════════════════════════════════ */
.hdr {
  position:fixed; top:0; left:0; right:0; height:var(--hdr-h);
  background:var(--bg2); border-bottom:1px solid var(--border2);
  display:flex; align-items:center; gap:12px; padding:0 14px; z-index:100;
}
.hdr-title {
  font-family:'Cinzel',serif; font-size:0.82rem; font-weight:700;
  color:var(--gold2); letter-spacing:0.12em; text-transform:uppercase;
  white-space:nowrap;
}
.hdr-sep { width:1px; height:22px; background:var(--border2); flex-shrink:0; }
.turn-badge {
  display:flex; align-items:center; gap:0; position:relative;
}
.tb-season-icon { font-size:1.1rem; line-height:1; }
.tb-text {
  display:flex; flex-direction:column; align-items:flex-start;
  margin-left:7px; line-height:1;
}
.tb-season {
  font-family:'Cinzel',serif; font-size:0.78rem; font-weight:700;
  letter-spacing:0.14em; text-transform:uppercase;
}
.tb-year {
  font-family:'IM Fell English',serif; font-style:italic;
  font-size:0.68rem; letter-spacing:0.04em; color:var(--text3);
  margin-top:1px;
}
.tb-year span { color:var(--gold2); font-style:normal; font-family:'Cinzel',serif; font-weight:700; font-size:0.75rem; }
.tb-turn {
  font-family:'Crimson Text',serif; font-size:0.58rem; color:var(--text3);
  margin-top:1px; letter-spacing:0.06em;
}
.hdr-right { margin-left:auto; display:flex; align-items:center; gap:8px; }
.role-badge {
  font-family:'Cinzel',serif; font-size:0.6rem; letter-spacing:0.1em;
  padding:2px 10px; border-radius:2px; text-transform:uppercase;
}
.role-badge.admin  { background:#1a1408; border:1px solid #7a6020; color:#c8a840; }
.role-badge.observer { background:#0a100a; border:1px solid #2a4020; color:#5a8040; }
.hdr-btn {
  font-family:'Cinzel',serif; font-size:0.58rem; letter-spacing:0.08em;
  background:var(--bg3); border:1px solid var(--border2); color:var(--text2);
  padding:3px 10px; cursor:pointer; transition:all 0.15s; text-transform:uppercase;
}
.hdr-btn:hover { border-color:var(--gold); color:var(--gold); }

/* ═══════════════════════════════════════════════════════════════════
   MAP MODE BAR
═══════════════════════════════════════════════════════════════════ */
.modebar {
  position:fixed; top:var(--hdr-h); left:0; right:0; height:30px;
  background:var(--bg); border-bottom:1px solid var(--border);
  display:flex; align-items:center; gap:2px; padding:0 10px; z-index:99;
  overflow-x:auto;
}
.modebar::-webkit-scrollbar { height:2px; }
.modebar::-webkit-scrollbar-thumb { background:var(--border2); }
.mode-group { display:flex; gap:1px; background:var(--bg2); border:1px solid var(--border); border-radius:2px; padding:1px; flex-shrink:0; }
.mmbtn {
  font-family:'Cinzel',serif; font-size:0.55rem; letter-spacing:0.06em;
  background:transparent; border:none; color:var(--muted);
  padding:2px 7px; cursor:pointer; transition:all 0.12s;
  white-space:nowrap; border-radius:1px;
}
.mmbtn:hover { color:var(--text); background:rgba(255,255,255,0.03); }
.mmbtn.active { color:var(--gold); background:rgba(200,168,64,0.08); font-weight:600; }
.mode-sep { width:1px; height:14px; background:var(--border); margin:0 4px; flex-shrink:0; }

/* ═══════════════════════════════════════════════════════════════════
   MAIN LAYOUT
═══════════════════════════════════════════════════════════════════ */
.main {
  position:fixed;
  top:calc(var(--hdr-h) + 30px);
  left:0; right:0; bottom:0;
  display:flex; overflow:hidden;
}
.canvas-area { flex:1; position:relative; overflow:hidden; background:#050705; }
#mapCanvas { position:absolute; top:0; left:0; transform-origin:0 0; image-rendering:pixelated; cursor:crosshair; }
#selectOverlay { position:absolute; top:0; left:0; transform-origin:0 0; image-rendering:pixelated; pointer-events:none; }
#labelSvg { position:absolute; top:0; left:0; width:100%; height:100%; pointer-events:none; overflow:visible; z-index:3; }

/* zoom HUD */
.zoom-hud {
  position:absolute; bottom:10px; right:10px; z-index:10;
  display:flex; align-items:center; gap:3px;
  background:rgba(8,11,7,0.85); border:1px solid var(--border2);
  padding:3px 6px; border-radius:3px;
}
.zoom-hud button {
  background:transparent; border:none; color:var(--text2); cursor:pointer;
  font-family:'Cinzel',serif; font-size:0.6rem; padding:1px 4px;
}
.zoom-hud button:hover { color:var(--gold); }
#zoomPct { font-family:'Cinzel',serif; font-size:0.6rem; color:var(--text3); min-width:34px; text-align:center; }

/* info bar */
.info-bar {
  position:absolute; bottom:0; left:0; right:0; height:20px;
  background:rgba(8,11,7,0.92); border-top:1px solid var(--border);
  display:flex; align-items:center; gap:16px; padding:0 10px;
  font-size:0.58rem; color:var(--text3); z-index:10;
}
.info-bar span { color:var(--text2); }

/* right panel */
.right-panel {
  width:0; overflow:hidden; background:var(--bg2);
  border-left:1px solid var(--border2);
  transition:width 0.22s ease; flex-shrink:0;
  display:flex; flex-direction:column;
}
.right-panel.open { width:var(--panel-w); }
.rp-head {
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 10px; border-bottom:1px solid var(--border);
  font-family:'Cinzel',serif; font-size:0.68rem; color:var(--gold);
  letter-spacing:0.08em; flex-shrink:0;
}
.rp-close { cursor:pointer; color:var(--text3); font-size:0.8rem; }
.rp-close:hover { color:var(--danger); }
.rp-scroll { flex:1; overflow-y:auto; overflow-x:hidden; padding:8px 10px; }
.rp-scroll::-webkit-scrollbar { width:4px; }
.rp-scroll::-webkit-scrollbar-thumb { background:var(--border2); }

/* panel sections */
.rp-section { margin-bottom:14px; }
.rp-section-title {
  font-family:'Cinzel',serif; font-size:0.6rem; color:var(--muted);
  letter-spacing:0.1em; text-transform:uppercase;
  border-bottom:1px solid var(--border); padding-bottom:4px; margin-bottom:8px;
}
.rp-row { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:4px; font-size:0.75rem; }
.rp-label { color:var(--text3); }
.rp-val { color:var(--text); font-family:'Crimson Text',serif; }
.rp-val.good { color:var(--green2); }
.rp-val.warn { color:#c8a040; }
.rp-val.none { color:var(--text3); font-style:italic; }
.rp-chip {
  display:inline-block; padding:1px 7px; margin:1px 2px;
  border-radius:2px; font-size:0.65rem;
  background:var(--bg3); border:1px solid var(--border2); color:var(--text2);
}
.rp-chips { margin-top:3px; }
.rp-pops-list { font-size:0.7rem; }
.rp-pop-row { padding:3px 0; border-bottom:1px solid var(--border); color:var(--text); }
.rp-pop-row .pop-eth { color:var(--gold); }
.rp-res-row { display:flex; justify-content:space-between; padding:2px 0; font-size:0.7rem; }
.rp-res-row .res-amt { color:var(--green); font-variant-numeric:tabular-nums; }
.rp-bar { height:3px; background:var(--border); border-radius:2px; margin-top:2px; margin-bottom:5px; }
.rp-bar-fill { height:100%; background:var(--green); border-radius:2px; transition:width 0.3s; }
/* admin-only tint */
.admin-only { display:none; }
body.is-admin .admin-only { display:block; }
body.is-admin .admin-only-flex { display:flex; }

/* ═══════════════════════════════════════════════════════════════════
   RADIAL MENU
═══════════════════════════════════════════════════════════════════ */
#radialMenu {
  position:absolute; z-index:50;
  display:none; pointer-events:none;
}
#radialMenu.visible { display:block; pointer-events:auto; }
.radial-backdrop {
  position:absolute; border-radius:50%;
  background:rgba(8,12,6,0.88);
  border:1px solid rgba(200,168,64,0.25);
  transform:translate(-50%,-50%);
  backdrop-filter:blur(3px);
}
.radial-btn {
  position:absolute; transform:translate(-50%,-50%);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  width:52px; height:52px; border-radius:50%; cursor:pointer;
  border:1px solid var(--border2); background:rgba(13,18,10,0.92);
  color:var(--text2); font-family:'Cinzel',serif; font-size:0.44rem;
  letter-spacing:0.06em; text-align:center; line-height:1.3;
  transition:all 0.12s; z-index:51;
}
.radial-btn:hover { border-color:var(--gold); color:var(--gold); background:rgba(24,30,16,0.98); transform:translate(-50%,-50%) scale(1.12); }
.radial-btn .icon { font-size:1.1rem; margin-bottom:2px; }
.radial-center-label {
  position:absolute; transform:translate(-50%,-50%);
  font-family:'Cinzel',serif; font-size:0.5rem; color:var(--muted);
  text-align:center; pointer-events:none; white-space:nowrap;
  max-width:60px; overflow:hidden; text-overflow:ellipsis;
}

/* ═══════════════════════════════════════════════════════════════════
   LOAD SCREEN / OVERLAY
═══════════════════════════════════════════════════════════════════ */
#loadScreen {
  position:fixed; inset:0; z-index:500;
  background:var(--bg);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:28px;
}
.load-title {
  font-family:'Cinzel',serif; font-size:1.6rem; font-weight:700;
  color:var(--gold2); letter-spacing:0.18em;
  text-shadow:0 0 40px rgba(200,168,64,0.3);
}
.load-sub {
  font-family:'IM Fell English',serif; font-style:italic;
  color:var(--text3); font-size:0.95rem; letter-spacing:0.04em;
}
.load-dropzone {
  width:360px; border:1px dashed var(--border2); border-radius:4px;
  padding:24px 20px; text-align:center; cursor:pointer;
  transition:all 0.2s; color:var(--text3);
  font-family:'Crimson Text',serif; font-size:0.85rem;
}
.load-dropzone:hover, .load-dropzone.drag-over {
  border-color:var(--gold); color:var(--gold); background:rgba(200,168,64,0.04);
}
.load-dropzone .dz-icon { font-size:2rem; margin-bottom:8px; }
.load-row { display:flex; gap:12px; width:360px; }
.load-file-btn {
  flex:1; padding:9px; font-family:'Cinzel',serif; font-size:0.62rem;
  letter-spacing:0.08em; border:1px solid var(--border2);
  background:var(--bg2); color:var(--text2); cursor:pointer;
  text-transform:uppercase; transition:all 0.15s;
}
.load-file-btn:hover { border-color:var(--gold); color:var(--gold); }
.load-status { font-size:0.75rem; color:var(--text3); font-family:'Crimson Text',serif; min-height:1.2em; }
.load-start-btn {
  padding:10px 40px; font-family:'Cinzel',serif; font-size:0.75rem;
  letter-spacing:0.12em; text-transform:uppercase;
  background:rgba(200,168,64,0.08); border:1px solid var(--gold);
  color:var(--gold); cursor:pointer; transition:all 0.2s;
  opacity:0.4; pointer-events:none;
}
.load-start-btn.ready { opacity:1; pointer-events:auto; }
.load-start-btn.ready:hover { background:rgba(200,168,64,0.18); }

/* ═══════════════════════════════════════════════════════════════════
   AUTH MODAL
═══════════════════════════════════════════════════════════════════ */
#authModal {
  position:fixed; inset:0; z-index:600;
  background:rgba(4,6,4,0.85);
  display:flex; align-items:center; justify-content:center;
}
.auth-box {
  background:var(--bg2); border:1px solid var(--border2);
  width:340px; padding:28px 24px;
  font-family:'Cinzel',serif;
}
.auth-title { font-size:0.9rem; color:var(--gold2); letter-spacing:0.12em; margin-bottom:6px; }
.auth-sub { font-family:'Crimson Text',serif; font-size:0.82rem; color:var(--text3); margin-bottom:18px; }
.auth-input {
  width:100%; padding:8px 10px; margin-bottom:10px;
  background:var(--bg); border:1px solid var(--border2);
  color:var(--text); font-family:'Crimson Text',serif; font-size:0.9rem;
  outline:none; transition:border-color 0.15s;
}
.auth-input:focus { border-color:var(--gold); }
.auth-input.error { border-color:var(--danger); }
.auth-err { color:var(--danger); font-family:'Crimson Text',serif; font-size:0.75rem; margin-bottom:8px; min-height:1.1em; }
.auth-btns { display:flex; gap:8px; margin-top:4px; }
.auth-btn {
  flex:1; padding:8px; font-family:'Cinzel',serif; font-size:0.6rem;
  letter-spacing:0.1em; text-transform:uppercase; cursor:pointer; transition:all 0.15s;
}
.auth-btn.primary { background:rgba(200,168,64,0.1); border:1px solid var(--gold); color:var(--gold); }
.auth-btn.primary:hover { background:rgba(200,168,64,0.2); }
.auth-btn.secondary { background:transparent; border:1px solid var(--border2); color:var(--text3); }
.auth-btn.secondary:hover { border-color:var(--text3); color:var(--text); }

/* ═══════════════════════════════════════════════════════════════════
   TOOLTIP
═══════════════════════════════════════════════════════════════════ */
#tooltip {
  position:fixed; z-index:200; pointer-events:none;
  background:rgba(8,12,6,0.92); border:1px solid var(--border2);
  padding:5px 9px; font-size:0.68rem; color:var(--text2);
  font-family:'Crimson Text',serif;
  max-width:200px; display:none;
}
#tooltip.visible { display:block; }
#tooltip .tt-name { font-family:'Cinzel',serif; font-size:0.7rem; color:var(--gold); letter-spacing:0.06em; }
#tooltip .tt-type { color:var(--text3); font-style:italic; font-size:0.6rem; }

/* ═══════════════════════════════════════════════════════════════════
   LIVE FEED
═══════════════════════════════════════════════════════════════════ */
#liveFeed {
  display:none; align-items:center; gap:7px;
  font-family:'Cinzel',serif; font-size:0.55rem;
  letter-spacing:0.07em; color:var(--text3);
}
#liveFeed.active { display:flex; }
.live-dot {
  width:7px; height:7px; border-radius:50%;
  background:var(--green); flex-shrink:0;
  box-shadow:0 0 6px var(--green);
}
.live-dot.stale { background:var(--muted); box-shadow:none; }
.live-dot.error { background:var(--danger); box-shadow:0 0 6px var(--danger); }
@keyframes livePulse {
  0%,100% { opacity:1; box-shadow:0 0 6px var(--green); }
  50%      { opacity:0.4; box-shadow:0 0 2px var(--green); }
}
.live-dot.pulsing { animation:livePulse 1.8s ease-in-out infinite; }
#liveLabel { color:var(--text2); }
#liveSub { color:var(--text3); font-size:0.5rem; }
#liveNextChk { color:var(--muted); }

/* New turn toast */
#newTurnToast {
  position:fixed; bottom:32px; left:50%; transform:translateX(-50%) translateY(20px);
  background:var(--bg2); border:1px solid var(--gold);
  padding:10px 24px; z-index:500; opacity:0;
  font-family:'Cinzel',serif; font-size:0.72rem; color:var(--gold2);
  letter-spacing:0.1em; text-align:center;
  transition:opacity 0.4s, transform 0.4s;
  pointer-events:none;
}
#newTurnToast.show {
  opacity:1; transform:translateX(-50%) translateY(0);
}

/* ═══════════════════════════════════════════════════════════════════
   MISC UI
═══════════════════════════════════════════════════════════════════ */
.legend-row {
  display:flex; flex-wrap:wrap; gap:8px; align-items:center;
  padding:0 10px; font-size:0.6rem;
}
.legend-item { display:flex; align-items:center; gap:4px; color:var(--text3); }
.legend-swatch { width:10px; height:10px; border-radius:1px; flex-shrink:0; }
#legendRow {
  position:fixed; bottom:20px; left:10px; z-index:20;
  background:rgba(8,12,6,0.82); border:1px solid var(--border);
  padding:4px 8px; display:none; border-radius:2px;
}
</style>
</head>
<body>

<!-- ════ LOAD SCREEN ════ -->
<div id="loadScreen">
  <div class="load-title">SUDOR</div>
  <div class="load-sub">Nnom's World — Game Viewer</div>

  <div class="load-dropzone" id="mapDZ">
    <div class="dz-icon">🗺</div>
    <div>Drop map image here<br><small style="font-size:0.75rem;color:var(--text3)">The original province colour map PNG</small></div>
  </div>

  <div class="load-row">
    <label class="load-file-btn">
      📁 Load Map Image
      <input type="file" id="mapFileIn" accept="image/*" style="display:none">
    </label>
    <label class="load-file-btn">
      💾 Load Game State
      <input type="file" id="stateFileIn" accept=".json" style="display:none">
    </label>
  </div>
  <div class="load-status" id="loadStatus">Awaiting files…</div>
  <button class="load-start-btn" id="startBtn" onclick="beginSession()">Enter World</button>
  <div style="font-size:0.68rem;color:var(--text3);font-family:'Crimson Text',serif;text-align:center;max-width:360px;line-height:1.6;margin-top:4px">
    After loading, use <strong style="color:var(--gold)">📤 Export Viewer</strong> (admin only) to generate a shareable HTML file with the map already baked in — no uploads needed for viewers.
  </div>
</div>

<!-- ════ AUTH MODAL ════ -->
<div id="authModal" style="display:none">
  <div class="auth-box">
    <div class="auth-title">Identify Yourself</div>
    <div class="auth-sub">Enter the admin password to gain full access, or continue as an observer with limited map visibility.</div>
    <input type="password" class="auth-input" id="authPwd" placeholder="Admin password…" onkeydown="if(event.key==='Enter')tryAdmin()">
    <div class="auth-err" id="authErr"></div>
    <div class="auth-btns">
      <button class="auth-btn primary" onclick="tryAdmin()">⚔ Enter as Admin</button>
      <button class="auth-btn secondary" onclick="enterObserver()">👁 Observe Only</button>
    </div>
  </div>
</div>

<!-- ════ HEADER ════ -->
<div class="hdr">
  <div class="hdr-title">⚔ Sudor</div>
  <div class="hdr-sep"></div>
  <div class="turn-badge" id="turnBadge">
    <span class="tb-season-icon" id="tbIcon">—</span>
    <div class="tb-text">
      <div class="tb-season" id="tbSeason" style="color:var(--muted)">—</div>
      <div class="tb-year">Year <span id="tbYear">—</span></div>
      <div class="tb-turn" id="tbTurn">Turn —</div>
    </div>
  </div>
  <div id="liveFeed">
    <div class="live-dot" id="liveDot"></div>
    <div style="display:flex;flex-direction:column;line-height:1.3">
      <span id="liveLabel">Live</span>
      <span id="liveSub" id="liveSub">—</span>
    </div>
    <span id="liveNextChk"></span>
  </div>
  <div class="hdr-sep" id="liveSep" style="display:none"></div>
  <div class="hdr-right">
    <span class="role-badge" id="roleBadge">—</span>
    <button class="hdr-btn admin-only" id="exportViewerBtn" onclick="exportViewer()"
      title="Bake map + game state into a standalone HTML file anyone can open">
      📤 Export Viewer
    </button>
    <button class="hdr-btn" id="configLiveBtn" onclick="showLiveConfig()"
      title="Configure live polling URL">⚡ Live Feed</button>
    <button class="hdr-btn" onclick="showAuthModal()">🔑 Switch Role</button>
  </div>
</div>

<!-- ════ MODEBAR ════ -->
<div class="modebar">
  <div class="mode-group">
    <button class="mmbtn" id="mm_default" onclick="setMode('default')">🗺 Default</button>
    <button class="mmbtn" id="mm_biome"   onclick="setMode('biome')">🌿 Biomes</button>
    <button class="mmbtn" id="mm_temp"    onclick="setMode('temp')">🌡 Temp</button>
    <button class="mmbtn" id="mm_rain"    onclick="setMode('rain')">🌧 Rain</button>
  </div>
  <div class="mode-sep"></div>
  <div class="mode-group">
    <button class="mmbtn" id="mm_region"   onclick="setMode('region')">📍 Regions</button>
    <button class="mmbtn" id="mm_religion" onclick="setMode('religion')">✝ Religion</button>
    <button class="mmbtn" id="mm_ethnicity"onclick="setMode('ethnicity')">👤 Ethnicity</button>
    <button class="mmbtn" id="mm_language" onclick="setMode('language')">🗣 Language</button>
  </div>
</div>

<!-- ════ MAIN ════ -->
<div class="main">
