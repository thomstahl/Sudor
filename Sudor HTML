function saveEdit(pid) {
  const p  = provinces[pid];
  if (!provinceData[p.hex]) return;
  const pd = provinceData[p.hex];

  const name = document.getElementById('ep_name')?.value?.trim();
  if (name !== undefined) pd.displayName = name || null;

  const temp = document.getElementById('ep_temp')?.value;
  if (temp !== undefined && temp !== '') pd.temp = parseFloat(temp);

  const precip = document.getElementById('ep_precip')?.value;
  if (precip !== undefined && precip !== '') pd.precip = parseFloat(precip);

  const wood = document.getElementById('ep_wood')?.value;
  if (wood !== undefined && wood !== '') pd.currentWood = parseFloat(wood);

  pd.spawnEthnicity = document.getElementById('ep_eth')?.value?.trim() || '';
  pd.spawnLanguage  = document.getElementById('ep_lang')?.value?.trim() || '';
  pd.spawnReligion  = document.getElementById('ep_rel')?.value?.trim() || '';

  // Resources
  if (pd.currentResources) {
    for (const k of Object.keys(pd.currentResources)) {
      const el = document.getElementById(`ep_res_${k}`);
      if (el) pd.currentResources[k] = Math.max(0, Math.min(pd.maxAmounts?.[k]||0, parseInt(el.value)||0));
    }
  }

  closePanel();
  redrawMap(); // re-render in case temp/precip changed
}

