function updateLoadStatus() {
  const el = document.getElementById('loadStatus');
  const btn = document.getElementById('startBtn');
  let parts = [];
  if (mapLoaded)   parts.push('✓ Map image');
  else             parts.push('○ Map image needed');
  if (stateLoaded) parts.push('✓ Game state');
  else             parts.push('○ Game state needed');
  el.textContent = parts.join('  ·  ');
  const ready = mapLoaded && stateLoaded;
  btn.classList.toggle('ready', ready);
}

// ── Auto-load embedded data if this is an exported viewer ──────────
(function checkEmbedded() {
  if (!EMBEDDED_MAP_SRC || !EMBEDDED_GAME_STATE) return;
  // Hide the load screen entirely — data is already baked in
  document.getElementById('loadScreen').style.display = 'none';
  // Load game state
  gameState   = EMBEDDED_GAME_STATE;
  stateLoaded = true;
  // Load map image from embedded base64
  const img = new Image();
  img.onload = () => {
    imgW = img.width; imgH = img.height;
    mapCanvas.width  = selOverlay.width  = imgW;
    mapCanvas.height = selOverlay.height = imgH;
    mCtx.drawImage(img, 0, 0);
    mapImageData = mCtx.getImageData(0, 0, imgW, imgH);
    mapLoaded = true;
    // Go straight to auth
    document.getElementById('authModal').style.display = 'flex';
  };
  img.src = EMBEDDED_MAP_SRC;
})();

