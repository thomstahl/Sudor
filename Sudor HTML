// ═══════════════════════════════════════════════════════════════════
//  SESSION INIT — build pidMap, provinces, centroids
// ═══════════════════════════════════════════════════════════════════
function initSession() {
  buildProvincesFromState();    // builds provinces + hexToPid
  buildPidMap();                // builds pidMap using hexToPid
  buildNeighbors();             // uses pidMap for fast adjacency
  buildBorderAndPixelLists();   // uses pidMap for borders + pixel lists
  buildCentroids();             // uses pidMap for province centers
  setTurnBadge();
  fitView();
  setupCamera();
  setMode('default');
  initLiveFeed();  // starts polling if LIVE_STATE_URL is set
}

function buildProvincesFromState() {
  // gameState.provinces is keyed by hex string
  provinceData = gameState.provinces || {};
  regions      = gameState.regions   || [];

  // Build numeric pid lookup from pixel analysis of the map
  // We scan the image for unique colours and assign pids
  const data = mapImageData.data;
  const colorCounts = {};
  for (let i = 0; i < data.length; i += 4) {
    const r=data[i],g=data[i+1],b=data[i+2];
    if (isRedMarker(r,g,b)) continue; // red cross pixels — handled by flood-fill later
    const hex = toHex(r,g,b);
    if (!colorCounts[hex]) colorCounts[hex] = {r,g,b,count:0};
    colorCounts[hex].count++;
  }

  // Classify each unique colour into a province
  let pid = 0;
  provinces = {};
  hexToPid  = {};

  // Sort by count desc for stable ordering
  const sorted = Object.entries(colorCounts).sort((a,b)=>b[1].count-a[1].count);

  for (const [hex, info] of sorted) {
    if (info.count < 3) continue; // skip dust pixels
    // Use game state type if available (most reliable), else classify by color
    const gsData = provinceData[hex];
    const type = gsData?.type || classifyHex(info.r, info.g, info.b);
    provinces[pid] = {
      id: pid, hex, r:info.r, g:info.g, b:info.b,
      type,
      traversable: gsData?.traversable ?? (type !== 'ice'),
      pixelCount: info.count,
      neighbors: [],
    };
    hexToPid[hex] = pid;
    pid++;
  }

  // Neighbors built after pidMap is ready (in initSession)
}

function toHex(r,g,b) {
  return '#'+[r,g,b].map(v=>v.toString(16).padStart(2,'0')).join('');
}
// Red cross marker pixels mark water province centers — must be excluded from province registration
// and flood-filled to their surrounding water province after pidMap is built.
function isRedMarker(r,g,b) {
  return Math.abs(r-233)<=10 && Math.abs(g-37)<=10 && Math.abs(b-28)<=10;
}

function classifyHex(r,g,b) {
  // Exact match like cartographer: white = ice, #090609 = water, rest = land
  if (r===255 && g===255 && b===255) return 'ice';
  if (r===9   && g===6   && b===9)   return 'water';
  return 'land';
}

function buildNeighbors() {
  // Use pidMap (already built) for O(pixels) neighbor detection — no string conversion
  const n = pidMap.length;
  const adjSets = {};
  for (const pid in provinces) adjSets[pid] = new Set();

  for (let p=0; p<n; p++) {
    const pidA = pidMap[p];
    if (pidA === -1) continue;
    // right neighbor
    if (p % imgW < imgW-1) {
      const pidB = pidMap[p+1];
      if (pidB !== -1 && pidB !== pidA) { adjSets[pidA].add(pidB); adjSets[pidB].add(pidA); }
    }
    // bottom neighbor
    if (p + imgW < n) {
      const pidB = pidMap[p+imgW];
      if (pidB !== -1 && pidB !== pidA) { adjSets[pidA].add(pidB); adjSets[pidB].add(pidA); }
    }
  }
  for (const pid in provinces) {
    provinces[pid].neighbors = [...adjSets[pid]];
  }
}

function buildPidMap() {
  const data = mapImageData.data;
  const n = imgW * imgH;
  pidMap = new Int32Array(n).fill(-1);

  // Pass A: assign all non-red pixels directly
  for (let p=0; p<n; p++) {
    const i = p<<2;
    const r=data[i],g=data[i+1],b=data[i+2];
    if (isRedMarker(r,g,b)) continue; // skip — flood-fill below
    const hex = toHex(r,g,b);
    const pid = hexToPid[hex];
    if (pid !== undefined) pidMap[p] = pid;
  }

  // Pass B: flood-fill red marker pixels from resolved neighbors (5 passes)
  for (let pass=0; pass<5; pass++) {
    for (let p=0; p<n; p++) {
      const i=p<<2;
      if (!isRedMarker(data[i],data[i+1],data[i+2])) continue;
      if (pidMap[p] !== -1) continue; // already resolved
      const x = p % imgW, y = (p/imgW)|0;
      if (x>0           && pidMap[p-1]     !== -1) { pidMap[p]=pidMap[p-1];     continue; }
      if (x<imgW-1      && pidMap[p+1]     !== -1) { pidMap[p]=pidMap[p+1];     continue; }
      if (y>0           && pidMap[p-imgW]  !== -1) { pidMap[p]=pidMap[p-imgW];  continue; }
      if (y<imgH-1      && pidMap[p+imgW]  !== -1) { pidMap[p]=pidMap[p+imgW];           }
    }
  }
}

function buildCentroids() {
  const sums = {};
  for (const pid in provinces) sums[pid] = {sx:0,sy:0,n:0};
  for (let y=0; y<imgH; y++) {
    for (let x=0; x<imgW; x++) {
      const pid = pidMap[y*imgW+x];
      if (pid < 0) continue;
      if (sums[pid]) { sums[pid].sx+=x; sums[pid].sy+=y; sums[pid].n++; }
    }
  }
  centroids = {};
  for (const pid in sums) {
    const s = sums[pid];
    if (s.n > 0) centroids[pid] = {x: s.sx/s.n, y: s.sy/s.n};
  }
}

function setTurnBadge() {
  const gs = gameState.globalState || {};
  const turn = gs.currentTurn || 1;
  const year = 1328 + Math.floor((turn-1)/4);
  const seasonIdx = (turn-1)%4;
