function loadMapFile(file) {
  const reader = new FileReader();
  reader.onload = ev => {
    const img = new Image();
    img.onload = () => {
      imgW = img.width; imgH = img.height;
      mapCanvas.width  = selOverlay.width  = imgW;
      mapCanvas.height = selOverlay.height = imgH;
      mCtx.drawImage(img, 0, 0);
      mapImageData = mCtx.getImageData(0, 0, imgW, imgH);
      mapDZ.innerHTML = `<div class="dz-icon">✓</div><div><strong style="color:var(--green2)">${file.name}</strong><br><small style="color:var(--text3)">${imgW}×${imgH}</small></div>`;
      mapLoaded = true;
      updateLoadStatus();
    };
    img.src = ev.target.result;
  };
  reader.readAsDataURL(file);
}

function loadStateFile(file) {
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      gameState = JSON.parse(ev.target.result);
      stateLoaded = true;
      document.getElementById('loadStatus').textContent =
        `✓ Game state — ${Object.keys(gameState.provinces||{}).length} provinces`;
      updateLoadStatus();
    } catch(e) {
      document.getElementById('loadStatus').textContent = '✗ Invalid JSON file';
    }
  };
  reader.readAsText(file);
}

