      `<div class="legend-item"><div class="legend-swatch" style="background:rgb(${r},${g},${b})"></div>${name}</div>`
    ).join('');
  }
  if (currentMode==='temp') {
    el.style.display='flex';
    const pts=[[-40,'Deep Freeze'],[-5,'Cold'],[5,'Cool'],[15,'Temperate'],[25,'Warm'],[35,'Hot'],[50,'Scorching']];
    el.innerHTML = pts.map(([t,l])=>{const [r,g,b]=getTempColor(t);return `<div class="legend-item"><div class="legend-swatch" style="background:rgb(${r},${g},${b})"></div>${l} (${t}°C)</div>`;}).join('');
  }
  if (currentMode==='rain') {
    el.style.display='flex';
    const pts=[[0,'Arid'],[250,'Dry'],[750,'Moderate'],[1500,'Wet'],[3000,'Very Wet'],[6000,'Soaked']];
    el.innerHTML = pts.map(([p,l])=>{const [r,g,b]=getRainColor(p);return `<div class="legend-item"><div class="legend-swatch" style="background:rgb(${r},${g},${b})"></div>${l} (${p}mm)</div>`;}).join('');
  }
