  if (seasonEl) { seasonEl.textContent = s.name; seasonEl.style.color = s.color; }
  if (yearEl)   yearEl.textContent   = year + ' A.E.';
  if (turnEl)   turnEl.textContent   = `Turn ${turn}`;
}

// ═══════════════════════════════════════════════════════════════════
//  COLOUR FUNCTIONS
// ═══════════════════════════════════════════════════════════════════
function getLandColor(pd) {
  if (!pd || pd.temp === null || pd.temp === undefined) return [108,108,108];
  const temp = Math.max(-40, Math.min(50, pd.temp));
  const woodFrac = Math.pow(Math.min(1,(pd.currentWood||0)/10000), 0.55);
  let lo=TEMP_COLOR_KEYS[0], hi=TEMP_COLOR_KEYS[TEMP_COLOR_KEYS.length-1];
  for (let i=0; i<TEMP_COLOR_KEYS.length-1; i++) {
    if (temp>=TEMP_COLOR_KEYS[i][0] && temp<=TEMP_COLOR_KEYS[i+1][0]) {
      lo=TEMP_COLOR_KEYS[i]; hi=TEMP_COLOR_KEYS[i+1]; break;
    }
  }
  const t = hi[0]===lo[0] ? 1 : (temp-lo[0])/(hi[0]-lo[0]);
  const lerp=(a,b,c,d)=>Math.round(a+t*(b-a)+woodFrac*((c+t*(d-c))-(a+t*(b-a))));
  return [lerp(lo[1][0],hi[1][0],lo[2][0],hi[2][0]),lerp(lo[1][1],hi[1][1],lo[2][1],hi[2][1]),lerp(lo[1][2],hi[1][2],lo[2][2],hi[2][2])];
}

function getTempColor(temp) {
  if (temp===null||temp===undefined) return [80,80,80];
  const stops=[[-40,[120,180,255]],[-20,[80,140,220]],[-5,[120,190,180]],[5,[100,180,100]],[15,[160,200,60]],[25,[220,200,30]],[35,[230,120,20]],[50,[210,40,20]]];
  let lo=stops[0],hi=stops[stops.length-1];
  for (let i=0;i<stops.length-1;i++){if(temp>=stops[i][0]&&temp<=stops[i+1][0]){lo=stops[i];hi=stops[i+1];break;}}
  const t=hi[0]===lo[0]?1:(temp-lo[0])/(hi[0]-lo[0]);
  return [Math.round(lo[1][0]+t*(hi[1][0]-lo[1][0])),Math.round(lo[1][1]+t*(hi[1][1]-lo[1][1])),Math.round(lo[1][2]+t*(hi[1][2]-lo[1][2]))];
}

function getRainColor(precip) {
  if (precip===null||precip===undefined) return [80,80,80];
  const stops=[[0,[210,180,120]],[250,[190,200,150]],[500,[140,195,160]],[1000,[80,170,180]],[2000,[40,130,200]],[4000,[20,80,180]],[8000,[10,40,150]]];
  let lo=stops[0],hi=stops[stops.length-1];
  for (let i=0;i<stops.length-1;i++){if(precip>=stops[i][0]&&precip<=stops[i+1][0]){lo=stops[i];hi=stops[i+1];break;}}
  const t=Math.min(1,hi[0]===lo[0]?1:(precip-lo[0])/(hi[0]-lo[0]));
  return [Math.round(lo[1][0]+t*(hi[1][0]-lo[1][0])),Math.round(lo[1][1]+t*(hi[1][1]-lo[1][1])),Math.round(lo[1][2]+t*(hi[1][2]-lo[1][2]))];
}

function getMajority(pops, prop) {
  if (!pops||!pops.length) return null;
  const cnt={};
  for (const p of pops){const v=p[prop];if(v)cnt[v]=(cnt[v]||0)+1;}
  let best=null,bestN=0;
  for (const [v,n] of Object.entries(cnt)){if(n>bestN){bestN=n;best=v;}}
  return best;
}

function getProvinceColor(pid) {
  const p   = provinces[pid];
  const pd  = provinceData[p.hex];

  if (currentMode === 'biome') {
    if (p.type==='ice')   return [210,225,240];
    if (p.type==='water') return [20,45,80];
    return BIOME_COLORS[pd?.biome] || [100,100,100];
  }
  if (currentMode === 'temp') {
    if (p.type==='ice')   return [200,220,255];
    if (p.type==='water') return [20,40,80];
    return getTempColor(pd?.temp??null);
  }
  if (currentMode === 'rain') {
    if (p.type==='ice')   return [200,220,255];
    if (p.type==='water') return [20,50,120];
    return getRainColor(pd?.precip??null);
  }
  if (currentMode === 'religion') {
    if (p.type!=='land') return p.type==='ice'?[180,200,220]:[15,25,45];
    const maj = getMajority(pd?.pops,'religion');
    return maj ? (RELIGION_COLORS[maj]||[80,80,80]) : [40,40,40];
  }
  if (currentMode === 'ethnicity') {
    if (p.type!=='land') return p.type==='ice'?[180,200,220]:[15,25,45];
    const maj = getMajority(pd?.pops,'ethnicity');
    return maj ? (ETHNICITY_COLORS[maj]||[80,80,80]) : [40,40,40];
  }
  if (currentMode === 'language') {
    if (p.type!=='land') return p.type==='ice'?[180,200,220]:[15,25,45];
    const maj = getMajority(pd?.pops,'language');
    return maj ? (LANGUAGE_COLORS[maj]||[80,80,80]) : [40,40,40];
  }
  if (currentMode === 'region') {
    const reg = getRegion(p.hex);
    if (reg) return hexToRgb(reg.color);
    if (p.type==='ice')   return [65,70,80];
    if (p.type==='water') return [12,22,42];
    return [32,32,30];
  }
  // default
  if (p.type==='ice') return [232,240,252];
  if (p.type==='water') {
    const wb = pd?.waterBiome;
    if (wb==='Lake')          return [52,82,128];
    if (wb==='Deep Water')    return [10,20,48];
    if (wb==='Abyssal Ocean') return [5,10,30];
    return [22,38,72];
  }
  return getLandColor(pd);
}

function hexToRgb(hex) {
  return [parseInt(hex.slice(1,3),16),parseInt(hex.slice(3,5),16),parseInt(hex.slice(5,7),16)];
}

function getRegion(provHex) {
  return regions.find(r => r.provinceHexes && r.provinceHexes.includes(provHex)) || null;
}

// ═══════════════════════════════════════════════════════════════════
//  MAP RENDERING — fast precomputed approach
// ═══════════════════════════════════════════════════════════════════
let maskBuf   = null;
let borderMap = null;   // Uint8Array: 1 if pixel is a border
let pixelLists = null;  // Map<pid, Uint32Array> of non-border pixel indices

// Called once after pidMap is built
function buildBorderAndPixelLists() {
  const n = pidMap.length;
  borderMap  = new Uint8Array(n);
  maskBuf    = new Uint8ClampedArray(n * 4);

  // Pre-fill alpha
  for (let i=3; i<n*4; i+=4) maskBuf[i] = 255;

  // Build borderMap: a pixel is a border if its right or bottom neighbor is a different province
  for (let p=0; p<n; p++) {
    const pid = pidMap[p];
    if (pid === -1) continue;
    if ((p % imgW < imgW-1 && pidMap[p+1]    !== pid) ||
        (p + imgW < n      && pidMap[p+imgW]  !== pid)) {
      borderMap[p] = 1;
    }
  }

  // Build per-province pixel lists (non-border only, for fast fill)
  const tempLists = {};
  for (const pid in provinces) tempLists[pid] = [];
  for (let p=0; p<n; p++) {
    const pid = pidMap[p];
    if (pid !== -1 && !borderMap[p] && tempLists[pid]) tempLists[pid].push(p);
  }
  pixelLists = new Map();
  for (const pid in tempLists) pixelLists.set(+pid, new Uint32Array(tempLists[pid]));
}

function redrawMap() {
  if (!pidMap || !borderMap || !pixelLists) return;

  // 1. Precompute one color per province (O(provinces), not O(pixels))
  let maxPid = 0;
  for (const pid in provinces) if (+pid > maxPid) maxPid = +pid;
  maxPid++;
  const cR = new Uint8Array(maxPid), cG = new Uint8Array(maxPid), cB = new Uint8Array(maxPid);
  for (const pid in provinces) {
    const [r,g,b] = getProvinceColor(+pid);
    cR[pid]=r; cG[pid]=g; cB[pid]=b;
  }

  // 2. Fill non-border pixels via pixel lists
  for (const [pid, pixels] of pixelLists) {
    const r=cR[pid], g=cG[pid], b=cB[pid];
    for (let k=0; k<pixels.length; k++) {
      const i = pixels[k] << 2;
      maskBuf[i]=r; maskBuf[i+1]=g; maskBuf[i+2]=b;
    }
  }

  // 3. Paint border pixels: dark gray for land, blue-gray for water
  const n = pidMap.length;
  for (let p=0; p<n; p++) {
    if (!borderMap[p]) continue;
    const i = p << 2;
    const pid = pidMap[p];
    if (pid !== -1 && provinces[pid]?.type === 'water') {
      maskBuf[i]=70; maskBuf[i+1]=80; maskBuf[i+2]=100;
    } else {
      maskBuf[i]=38; maskBuf[i+1]=38; maskBuf[i+2]=38;
    }
  }

  mCtx.putImageData(new ImageData(maskBuf, imgW, imgH), 0, 0);
  applyTransform();
  rebuildSelOverlay();
}

function applyTransform() {
  const t = `translate(${camX}px,${camY}px) scale(${camZ})`;
  mapCanvas.style.transform = t;
  selOverlay.style.transform = t;
  document.getElementById('labelSvg').style.transform = t;
  document.getElementById('zoomPct').textContent = Math.round(camZ*100)+'%';
}

// ── Selection overlay — fast pixel-list based approach ──────────────
let selBuf = null;
function rebuildSelOverlay() {
  if (!pidMap || !pixelLists) return;
  if (!selBuf || selBuf.length !== imgW*imgH*4) selBuf = new Uint8ClampedArray(imgW*imgH*4);
  else selBuf.fill(0);

  // Neighbor highlight tint
  for (const npid of highlightedPids) {
    const pixels = pixelLists.get(npid);
    if (!pixels) continue;
    for (let k=0; k<pixels.length; k++) {
      const i = pixels[k] << 2;
      selBuf[i]=200; selBuf[i+1]=168; selBuf[i+2]=64; selBuf[i+3]=46;
    }
  }

  // Selected province: tint interior + bright border
  if (selectedPid !== null) {
    const pixels = pixelLists.get(selectedPid);
    if (pixels) {
      for (let k=0; k<pixels.length; k++) {
        const i = pixels[k] << 2;
        selBuf[i]=200; selBuf[i+1]=168; selBuf[i+2]=64; selBuf[i+3]=110;
      }
    }
    // Border: scan pidMap for selected province border pixels
    const n = pidMap.length;
    for (let p=0; p<n; p++) {
      if (pidMap[p] !== selectedPid) continue;
      const x = p % imgW, y = (p / imgW)|0;
      const isEdge = (x>0&&pidMap[p-1]!==selectedPid)||(x<imgW-1&&pidMap[p+1]!==selectedPid)||
                     (y>0&&pidMap[p-imgW]!==selectedPid)||(y<imgH-1&&pidMap[p+imgW]!==selectedPid);
      if (isEdge) { const i=p<<2; selBuf[i]=255;selBuf[i+1]=220;selBuf[i+2]=80;selBuf[i+3]=220; }
    }
  }

  sCtx.putImageData(new ImageData(selBuf, imgW, imgH), 0, 0);
}

