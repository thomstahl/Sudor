  }
}

// ═══════════════════════════════════════════════════════════════════
//  CAMERA
// ═══════════════════════════════════════════════════════════════════
function fitView() {
  const area = canvasArea.getBoundingClientRect();
  const scaleX = area.width  / imgW;
  const scaleY = area.height / imgH;
  camZ = Math.min(scaleX, scaleY) * 0.95;
  camX = (area.width  - imgW*camZ)/2;
  camY = (area.height - imgH*camZ)/2;
  applyTransform();
}

function adjZoom(factor) {
  const area = canvasArea.getBoundingClientRect();
  const cx = area.width/2, cy = area.height/2;
  const newZ = Math.max(0.05, Math.min(32, camZ*factor));
  camX = cx - (cx-camX)*(newZ/camZ);
  camY = cy - (cy-camY)*(newZ/camZ);
  camZ = newZ;
  applyTransform();
}

function setupCamera() {
  canvasArea.addEventListener('wheel', e=>{
    e.preventDefault();
    const rect = canvasArea.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const factor = e.deltaY < 0 ? 1.15 : 1/1.15;
    const newZ = Math.max(0.05, Math.min(32, camZ*factor));
    camX = mx - (mx-camX)*(newZ/camZ);
    camY = my - (my-camY)*(newZ/camZ);
    camZ = newZ;
    applyTransform();
  }, {passive:false});

  canvasArea.addEventListener('mousedown', e=>{
    if (e.button===1 || (e.button===0 && e.altKey)) {
      panning=true; panSX=e.clientX; panSY=e.clientY; panCX=camX; panCY=camY;
      canvasArea.style.cursor='grabbing'; e.preventDefault();
    }
  });
  window.addEventListener('mousemove', e=>{
    if (panning) {
      camX = panCX+(e.clientX-panSX);
      camY = panCY+(e.clientY-panSY);
      applyTransform(); return;
    }
    handleHover(e);
  });
  window.addEventListener('mouseup', e=>{
    if (panning) { panning=false; canvasArea.style.cursor=''; }
  });

  canvasArea.addEventListener('click', e=>{
    if (e.altKey) return;
    const pid = getPidAtEvent(e);
    if (pid === null) { deselectAll(); return; }
    selectProvince(pid, e.clientX, e.clientY);
  });

  document.addEventListener('keydown', e=>{
    if (e.key==='f'||e.key==='F') fitView();
    if (e.key==='Escape') { deselectAll(); closePanel(); closeRadial(); }
  });
}

function getPidAtEvent(e) {
  const rect = canvasArea.getBoundingClientRect();
  const mx = (e.clientX - rect.left - camX) / camZ;
  const my = (e.clientY - rect.top  - camY) / camZ;
  const x = Math.floor(mx), y = Math.floor(my);
  if (x<0||y<0||x>=imgW||y>=imgH) return null;
  const pid = pidMap[y*imgW+x];
  return pid < 0 ? null : pid;
}

function handleHover(e) {
  const pid = getPidAtEvent(e);
  tooltip.classList.toggle('visible', pid!==null);
  if (pid===null) {
    updateInfoBar(null); return;
  }
  const p  = provinces[pid];
  const pd = provinceData[p.hex];
  tooltip.style.left = (e.clientX+12)+'px';
  tooltip.style.top  = (e.clientY-6)+'px';
  document.getElementById('ttName').textContent = pd?.displayName || `Province #${pid}`;
  document.getElementById('ttType').textContent = p.type + (pd?.biome ? ' · '+pd.biome : '');
  updateInfoBar(pid, pd, p);
}

function updateInfoBar(pid, pd, p) {
  document.getElementById('ibProv').textContent  = pid!==null ? (pd?.displayName||`#${pid}`) : '—';
  document.getElementById('ibBiome').textContent = pd?.biome  || (p?.waterBiome)||'—';
  document.getElementById('ibTemp').textContent  = pd?.temp!=null ? pd.temp+'°C' : '—';
  document.getElementById('ibRain').textContent  = pd?.precip!=null ? pd.precip+'mm' : '—';
}

// ═══════════════════════════════════════════════════════════════════
//  PROVINCE SELECTION + RADIAL MENU
// ═══════════════════════════════════════════════════════════════════
function selectProvince(pid, screenX, screenY) {
  selectedPid = pid;
  highlightedPids = new Set(provinces[pid].neighbors || []);
  rebuildSelOverlay();
  showRadial(pid, screenX, screenY);
}

function deselectAll() {
  selectedPid = null;
  highlightedPids.clear();
  rebuildSelOverlay();
  closeRadial();
}

function closePanel() {
  document.getElementById('rightPanel').classList.remove('open');
}

function closeRadial() {
  radialMenu.classList.remove('visible');
  radialMenu.innerHTML = '<div class="radial-backdrop" id="radialBg"></div><div class="radial-center-label" id="radialLabel"></div>';
}

function showRadial(pid, screenX, screenY) {
  const p  = provinces[pid];
  const pd = provinceData[p.hex];

  // Position at click, clamped to viewport
  const area = canvasArea.getBoundingClientRect();
  const rx = screenX - area.left;
  const ry = screenY - area.top;

  // Determine which buttons to show
  const isLand  = p.type === 'land';
  const isWater = p.type === 'water';

  const btns = [];
  // All provinces
  btns.push({ icon:'ℹ', label:'General\nInfo', action:()=>showGeneralInfo(pid) });
  if (isLand) {
    btns.push({ icon:'👥', label:'Pop\nInfo',     action:()=>showPopInfo(pid) });
    btns.push({ icon:'🌿', label:'Life\nInfo',    action:()=>showLifeInfo(pid) });
    if (isAdmin) {
      btns.push({ icon:'⛏', label:'Resource\nInfo', action:()=>showResourceInfo(pid) });
    }
  }
  if (isWater && isAdmin) {
    btns.push({ icon:'🐟', label:'Fish\nInfo', action:()=>showFishInfo(pid) });
  }
  if (isAdmin) {
    btns.push({ icon:'✏', label:'Edit', action:()=>openEditPanel(pid) });
  }

  const N = btns.length;
  // Scale radius with zoom but clamp sensibly for screen space
  const baseR = Math.max(55, Math.min(90, 55 * Math.sqrt(camZ)));
  const backdropR = baseR + 30;

  radialMenu.style.left = rx+'px';
  radialMenu.style.top  = ry+'px';

  // Rebuild DOM
  radialMenu.innerHTML = '';

  // Backdrop circle
  const bd = document.createElement('div');
  bd.className = 'radial-backdrop';
  bd.style.width = bd.style.height = (backdropR*2)+'px';
  bd.style.transform = 'translate(-50%,-50%)';
  radialMenu.appendChild(bd);

  // Center label — name + region
  const reg2 = getRegion(p.hex);
  const cl = document.createElement('div');
  cl.className = 'radial-center-label';
  const provName = pd?.displayName || `Province #${pid}`;
  cl.innerHTML = `<span style="color:var(--gold);font-size:0.52rem">${provName}</span>${reg2?`<br><span style="color:${reg2.color};font-size:0.44rem">${reg2.name}</span>`:''}`;
  radialMenu.appendChild(cl);

  // Buttons arranged in a circle
  for (let i=0; i<N; i++) {
    const angle = (2*Math.PI*i/N) - Math.PI/2;
    const bx = Math.round(Math.cos(angle)*baseR);
    const by = Math.round(Math.sin(angle)*baseR);
    const btn = document.createElement('div');
    btn.className = 'radial-btn';
    btn.style.left = (50 + bx/backdropR*50) + '%';
    btn.style.top  = (50 + by/backdropR*50) + '%';
    btn.innerHTML = `<span class="icon">${btns[i].icon}</span>${btns[i].label.replace('\n','<br>')}`;
    btn.addEventListener('click', e=>{ e.stopPropagation(); closeRadial(); btns[i].action(); });
    radialMenu.appendChild(btn);
  }

  // Close on outside click
  radialMenu.classList.add('visible');
  setTimeout(()=>document.addEventListener('click', closeOnOutside, {once:true}), 10);
}

function closeOnOutside(e) {
  if (!radialMenu.contains(e.target)) closeRadial();
}

