        <span class="rp-label">Current Wood</span>
        <input id="ep_wood" type="number" min="0" style="width:100%;background:var(--bg);border:1px solid var(--border2);color:var(--text);padding:4px 6px;font-family:'Crimson Text',serif" value="${pd?.currentWood??0}">
