function applyLiveConfig(overlay) {
  const url = document.getElementById('liveUrlInput').value.trim();
  if (!url) return;
  LIVE_STATE_URL = url;
  overlay.remove();
  if (liveTimer) clearInterval(liveTimer);
  liveEnabled = false;
  liveLastTurn = -1;
  if (sessionActive) initLiveFeed();
}

function disableLiveFeed() {
  LIVE_STATE_URL = null;
  liveEnabled = false;
  if (liveTimer) { clearInterval(liveTimer); liveTimer = null; }
  document.getElementById('liveFeed').classList.remove('active');
  document.getElementById('liveSep').style.display = 'none';
}
const POLL_INTERVAL   = 60;   // seconds between checks
let liveEnabled       = false;
let liveTimer         = null;
let liveCountdown     = 0;
let liveLastTurn      = -1;
let liveLastChecked   = null;
let liveError         = false;

function initLiveFeed() {
  if (!LIVE_STATE_URL || !sessionActive) return;
  liveEnabled = true;
  document.getElementById('liveFeed').classList.add('active');
  document.getElementById('liveSep').style.display = '';
  document.getElementById('liveDot').classList.add('pulsing');
  setLiveLabel('Connecting…', '');
  pollLiveFeed();           // immediate first check
  startCountdown();
}

async function pollLiveFeed() {
  if (!liveEnabled || !LIVE_STATE_URL) return;
  const dot = document.getElementById('liveDot');
  dot.classList.add('pulsing');
  setLiveLabel('Checking…', '');

  try {
    // Cache-bust so GitHub CDN doesn't return a stale response
    const url = LIVE_STATE_URL + '?_=' + Date.now();
    const resp = await fetch(url, {cache:'no-store'});
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const data = await resp.json();

    liveError = false;
    dot.classList.remove('error','stale');
    dot.classList.add('pulsing');

    const newTurn = data.globalState?.currentTurn ?? -1;
    liveLastChecked = new Date();

    if (liveLastTurn === -1) {
      // First successful load — use this as our baseline
      liveLastTurn = newTurn;
      setLiveLabel('Live', formatLastChecked());
    } else if (newTurn > liveLastTurn) {
      // New turn detected — hot-reload state and redraw
      liveLastTurn = newTurn;
      await hotReloadState(data);
      showNewTurnToast(newTurn);
      setLiveLabel('Live', formatLastChecked());
    } else {
      setLiveLabel('Live', formatLastChecked());
    }
  } catch(e) {
    liveError = true;
    dot.classList.remove('pulsing');
    dot.classList.add('error');
    setLiveLabel('Unreachable', 'Check URL');
    console.warn('Live feed error:', e);
  }

  liveCountdown = POLL_INTERVAL;
}

function startCountdown() {
  if (liveTimer) clearInterval(liveTimer);
  liveCountdown = POLL_INTERVAL;
  liveTimer = setInterval(() => {
    liveCountdown--;
    updateCountdownDisplay();
    if (liveCountdown <= 0) {
      liveCountdown = POLL_INTERVAL;
      pollLiveFeed();
    }
  }, 1000);
}

function updateCountdownDisplay() {
  const el = document.getElementById('liveNextChk');
  if (!el) return;
  if (liveError) { el.textContent = ''; return; }
  el.textContent = liveCountdown > 0 ? `↻ ${liveCountdown}s` : '↻ now';
}

function setLiveLabel(main, sub) {
  const lbl = document.getElementById('liveLabel');
  const sub_ = document.getElementById('liveSub');
  if (lbl) lbl.textContent = main;
  if (sub_) sub_.textContent = sub;
}

function formatLastChecked() {
  if (!liveLastChecked) return '';
  const h = liveLastChecked.getHours().toString().padStart(2,'0');
  const m = liveLastChecked.getMinutes().toString().padStart(2,'0');
  return `Updated ${h}:${m}`;
}

async function hotReloadState(newGameState) {
  // Update game state data without reinitialising the entire map
  // (pidMap, borders, pixel lists stay the same — only data changes)
  gameState    = newGameState;
  provinceData = newGameState.provinces || {};
  regions      = newGameState.regions   || [];
  setTurnBadge();
  redrawMap();
  // Close any open panel since province data may have changed
  closePanel();
  deselectAll();
}

function showNewTurnToast(turn) {
  const gs = gameState.globalState || {};
  const year = 1328 + Math.floor((turn-1)/4);
  const seasons = ['Spring','Summer','Autumn','Winter'];
  const season = seasons[(turn-1)%4];
  const toast = document.getElementById('newTurnToast');
  toast.textContent = `⚔ Turn ${turn} — ${season} ${year} A.E.`;
  toast.classList.add('show');
  setTimeout(() => toast.classList.remove('show'), 5000);
}

// ── Manual refresh button ────────────────────────────────────────
function manualRefresh() {
  liveCountdown = 0;
  pollLiveFeed();
  startCountdown();
}

// ═══════════════════════════════════════════════════════════════════
//  EXPORT (save edited game state)
// ═══════════════════════════════════════════════════════════════════
function exportState() {
  if (!gameState) return;
  gameState.provinces = provinceData;
  const blob = new Blob([JSON.stringify(gameState, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'game_state_exported.json';
  a.click();
}

// ── Export Viewer ─────────────────────────────────────────────────
// Generates a fully self-contained HTML file with the map image and
// game state baked in. Anyone can open it without uploading anything.
async function exportViewer() {
  if (!mapImageData || !gameState) {
    alert('Load a map and game state first.'); return;
  }

  // Show progress overlay
  const prog = document.createElement('div');
  prog.style.cssText = 'position:fixed;inset:0;z-index:900;background:rgba(4,6,4,0.92);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px';
  prog.innerHTML = '<div style="font-family:Cinzel,serif;color:var(--gold);font-size:0.9rem;letter-spacing:0.12em">Baking Viewer…</div>' +
    '<div id="bakeStatus" style="font-size:0.75rem;color:var(--text3);font-family:Crimson Text,serif">Encoding map image…</div>' +
    '<div style="width:260px;height:3px;background:var(--border);border-radius:2px"><div id="bakeBar" style="height:100%;background:var(--gold);border-radius:2px;width:0%;transition:width 0.3s"></div></div>';
  document.body.appendChild(prog);
  const setStatus = (msg, pct) => {
    prog.querySelector('#bakeStatus').textContent = msg;
    prog.querySelector('#bakeBar').style.width = pct + '%';
  };

  await new Promise(r => setTimeout(r, 30)); // let UI paint

  // Step 1: encode map image as PNG base64 data URL
  setStatus('Encoding map image…', 10);
  await new Promise(r => setTimeout(r, 10));
  const offscreen = document.createElement('canvas');
  offscreen.width = imgW; offscreen.height = imgH;
  offscreen.getContext('2d').putImageData(mapImageData, 0, 0);
  const mapDataUrl = offscreen.toDataURL('image/png');
  setStatus('Serialising game state…', 40);
  await new Promise(r => setTimeout(r, 10));

  // Step 2: serialise game state (sync current provinceData edits in)
  const stateSnapshot = JSON.parse(JSON.stringify(gameState));
  stateSnapshot.provinces = provinceData;
  const stateJson = JSON.stringify(stateSnapshot);
  setStatus('Assembling HTML…', 65);
  await new Promise(r => setTimeout(r, 10));

  // Step 3: read this very HTML file's source and splice the data in
  const resp = await fetch(window.location.href).catch(() => null);
  let src;
  if (resp && resp.ok) {
    src = await resp.text();
  } else {
    // Fallback: reconstruct from DOM (works when opened as file://)
    src = '<!DOCTYPE html>\n' + document.documentElement.outerHTML;
  }

  // Replace the two embed slots with the actual data
  const escapedMap   = mapDataUrl.replace(/\\/g, '\\\\').replace(/`/g, '\\`');
  const escapedState = stateJson.replace(/\\/g, '\\\\').replace(/`/g, '\\`');

  // Replace sentinel lines — works whether src is the original template or a prior export
  src = src.replace(
    /const EMBEDDED_MAP_SRC[ ]*= [^;]+;/,
    'const EMBEDDED_MAP_SRC   = `' + escapedMap + '`;'
  );
  src = src.replace(
    /const EMBEDDED_GAME_STATE[ ]*= [^;\n]+[;\n]/,
    'const EMBEDDED_GAME_STATE = ' + stateJson + ';\n'
  );
  // Preserve the LIVE_STATE_URL from the current session if it's been configured
  if (LIVE_STATE_URL) {
    src = src.replace(
      /const LIVE_STATE_URL[ ]*= [^;]+;/,
      'const LIVE_STATE_URL = ' + JSON.stringify(LIVE_STATE_URL) + ';'
    );
  }

  setStatus('Downloading…', 90);
  await new Promise(r => setTimeout(r, 10));

  // Step 4: trigger download
  const blob = new Blob([src], {type:'text/html'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  const gs = gameState.globalState || {};
  const turn = gs.currentTurn || 1;
  const year = 1328 + Math.floor((turn-1)/4);
  const seasons = ['Spring','Summer','Autumn','Winter'];
  const season = seasons[(turn-1)%4];
  a.download = `sudor_viewer_${season.toLowerCase()}_${year}.html`;
  a.click();
  URL.revokeObjectURL(a.href);

  setStatus('Done!', 100);
  await new Promise(r => setTimeout(r, 600));
  prog.remove();
}
