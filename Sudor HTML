//  LIVE FEED — polls GitHub raw URL for state updates
// ═══════════════════════════════════════════════════════════════════
function showLiveConfig() {
  const current = LIVE_STATE_URL || '';
  const overlay = document.createElement('div');
  overlay.style.cssText = 'position:fixed;inset:0;z-index:800;background:rgba(4,6,4,0.88);display:flex;align-items:center;justify-content:center';
  overlay.innerHTML = `
    <div style="background:var(--bg2);border:1px solid var(--border2);width:460px;padding:24px 22px;font-family:'Cinzel',serif">
      <div style="font-size:0.85rem;color:var(--gold2);letter-spacing:0.1em;margin-bottom:6px">⚡ Live Feed Configuration</div>
      <div style="font-family:'Crimson Text',serif;font-size:0.8rem;color:var(--text3);margin-bottom:16px;line-height:1.6">
        Paste the <strong style="color:var(--text2)">GitHub raw URL</strong> of your <code style="color:var(--green)">state.json</code> file.<br>
        Example: <code style="color:var(--muted);font-size:0.72rem">https://raw.githubusercontent.com/you/sudor/main/state.json</code>
      </div>
      <input id="liveUrlInput" type="url"
        style="width:100%;padding:8px 10px;background:var(--bg);border:1px solid var(--border2);color:var(--text);font-family:'Crimson Text',serif;font-size:0.85rem;margin-bottom:4px;outline:none"
        placeholder="https://raw.githubusercontent.com/…/state.json"
        value="${current}">
      <div style="font-size:0.65rem;color:var(--text3);font-family:'Crimson Text',serif;margin-bottom:14px">
        Poll interval: every ${POLL_INTERVAL} seconds. The map refreshes automatically when a new turn is detected.
      </div>
      <div style="display:flex;gap:8px">
        <button onclick="applyLiveConfig(this.closest('div[style]'))"
          style="flex:1;padding:8px;font-family:'Cinzel',serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;background:rgba(200,168,64,0.1);border:1px solid var(--gold);color:var(--gold)">
          ⚡ Enable Live Feed
        </button>
        <button onclick="disableLiveFeed();this.closest('div[style]').remove()"
          style="flex:1;padding:8px;font-family:'Cinzel',serif;font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;background:transparent;border:1px solid var(--border2);color:var(--text3)">
